# --- Servidor ---
NODE_ENV=development
PORT=4000

# Secretos (cambiar en producción; usar un gestor de secretos real)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=3600

# Base de datos PostgreSQL
DATABASE_URL=postgresql://bet:betpass@localhost:5432/betmundial
DATABASE_POOL_MAX=10

# --- Reglas de negocio / cumplimiento ---
# Jurisdicciones permitidas (ISO 3166-1 alpha-2, separadas por coma)
ALLOWED_JURISDICTIONS=ES,MX,CO,PE,AR,CL,UK,MT
# Edad mínima global de respaldo (cada jurisdicción puede sobreescribirla)
MIN_AGE=18
# Límite de depósito diario por defecto (en céntimos / minor units)
DEFAULT_DAILY_DEPOSIT_LIMIT=50000
# Apuesta máxima por defecto por selección (minor units)
DEFAULT_MAX_STAKE=20000
# Umbral AML para marcar transacciones grandes (minor units)
AML_LARGE_TX_THRESHOLD=200000

# --- Antifraude ---
# Máximo de apuestas por usuario en la ventana (velocity)
FRAUD_MAX_BETS_PER_MINUTE=20
# Máximo de peticiones por IP por minuto (rate limit global)
RATE_LIMIT_PER_MINUTE=120

# --- Proveedores pluggable (pagos y KYC) ---
# Implementación a usar: 'sandbox' confirma de forma síncrona (demo) o 'stripe'.
PAYMENT_PROVIDER=sandbox
KYC_PROVIDER=sandbox
# Secreto para verificar la firma de los webhooks del proveedor sandbox.
PAYMENTS_WEBHOOK_SECRET=sandbox-webhook-secret

# Stripe (sólo si PAYMENT_PROVIDER=stripe). Usa claves de test (sk_test_...) para
# la demo. El depósito abre Checkout y se confirma vía webhook firmado.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# URLs de retorno tras el pago (Checkout redirige aquí).
STRIPE_SUCCESS_URL=http://localhost:5173/?deposit=ok
STRIPE_CANCEL_URL=http://localhost:5173/?deposit=cancel

# --- Administrador ---
# Si defines ambas, el arranque crea (o rota la contraseña de) este admin.
# En producción NO hay admin por defecto: configúralas para tener acceso seguro.
# Cambiar ADMIN_PASSWORD y redesplegar rota la contraseña del administrador.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Multi-operador (SaaS) ---
# Operador usado cuando una petición no indica uno (cabecera X-Operator-Id).
# En una instalación de un solo operador, déjalo en op_default.
DEFAULT_OPERATOR_ID=op_default

# --- Operación / despliegue ---
# Redis (opcional). Si se define, habilita rate-limit distribuido y difusión de
# cuotas entre varias instancias. Vacío => modo de una sola instancia (memoria).
REDIS_URL=
# Nivel de log: debug | info | warn | error
LOG_LEVEL=info
# Orígenes CORS permitidos (coma). En producción es OBLIGATORIO enumerarlos.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
# Saltos de proxy de confianza (1 si hay un load balancer / nginx delante).
TRUST_PROXY=0
# Exponer /metrics (Prometheus). 'false' para desactivar.
METRICS_ENABLED=true

# --- Frontend ---
VITE_API_URL=http://localhost:4000
